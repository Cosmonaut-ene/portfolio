---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/portfolio/' },
  { label: 'Projects', href: '/portfolio/projects/' },
  { label: 'Blog', href: '/portfolio/blog/' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body style="background-color: #F0EDE8; color: #1a1a1a; font-family: sans-serif; font-size: 15px; margin: 0;">
    <nav style="padding: 2rem 3rem; border-bottom: 0.5px solid #d8d4ce; display: flex; gap: 2rem;">
      {navLinks.map(({ label, href }) => {
        const isActive = pathname === href || (href !== '/portfolio/' && pathname.startsWith(href));
        return (
          <a
            href={href}
            style={`text-decoration: none; font-size: 13px; letter-spacing: 0.05em; color: ${isActive ? '#D97706' : '#6b6b6b'};`}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <main>
      <slot />
    </main>

    <footer style="padding: 2.5rem 3rem; border-top: 0.5px solid #d8d4ce; color: #9b9690; font-size: 13px;">
      © {new Date().getFullYear()} Zhang
    </footer>
  </body>
</html>
