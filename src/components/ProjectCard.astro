---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<div style="padding: 1.75rem 0; border-bottom: 0.5px solid #d8d4ce; display: flex; gap: 1.5rem;">
  <!-- Row number -->
  <span style="font-family: Georgia, serif; font-size: 11px; color: #b5b0aa; min-width: 1.5rem; padding-top: 3px;">
    {String(index + 1).padStart(2, '0')}
  </span>

  <div style="flex: 1;">
    <!-- Title + arrow -->
    <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.5rem;">
      <a
        href={project.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="color: #1a1a1a; text-decoration: none; font-size: 15px; font-weight: 500;"
      >
        {project.title}
      </a>
      <span style="color: #D97706; font-size: 16px;">↗</span>
    </div>

    <!-- Description -->
    <p style="font-size: 13px; color: #6b6b6b; line-height: 1.6; margin: 0 0 0.75rem;">
      {project.description}
    </p>

    <!-- Tech tags -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
      {project.techStack.map(tech => (
        <span style="background: #e4e0da; color: #9b9690; font-size: 11px; padding: 3px 8px;">
          {tech}
        </span>
      ))}
    </div>
  </div>
</div>
