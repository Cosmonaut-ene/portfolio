---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Zhang — Portfolio">
  <!-- Hero -->
  <section style="padding: 4rem 3rem; border-bottom: 0.5px solid #d8d4ce;">
    <p style="font-size: 11px; color: #9b9690; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 1.5rem;">
      AI / Backend Engineer
    </p>
    <h1 style="font-family: Georgia, serif; font-weight: 300; font-size: 2.25rem; color: #1a1a1a; margin: 0 0 1.25rem; line-height: 1.2;">
      Zhang
    </h1>
    <p style="font-size: 15px; color: #6b6b6b; max-width: 520px; line-height: 1.7; margin: 0 0 2rem;">
      I build AI-powered systems — RAG pipelines, autonomous agents, and full-stack
      applications. Currently seeking graduate roles in Australia.
    </p>

    <!-- TASK-03: CTA links -->
    <div style="display: flex; gap: 2rem; align-items: center;">
      <a
        href="/portfolio/projects/"
        style="color: #D97706; text-decoration: none; border-bottom: 1.5px solid #D97706; font-size: 14px; padding-bottom: 1px;"
      >
        View Projects →
      </a>
      <a
        href="/portfolio/blog/"
        style="color: #9b9690; text-decoration: none; font-size: 14px;"
      >
        Read Blog
      </a>
    </div>
  </section>

  <!-- TASK-02: Tech stack -->
  <section style="padding: 2.5rem 3rem;">
    <p style="font-size: 11px; color: #9b9690; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 1.25rem;">
      Core Stack
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {['Python', 'LangGraph', 'FastAPI', 'Next.js', 'RAG', 'PostgreSQL', 'Docker', 'GitHub Actions'].map(tech => (
        <span style="background: #e4e0da; color: #9b9690; font-size: 11px; padding: 3px 8px;">
          {tech}
        </span>
      ))}
    </div>
  </section>
</Layout>
