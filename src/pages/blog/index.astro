---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — Zhang">
  <section style="padding: 4rem 3rem 0;">
    <p style="font-size: 11px; color: #9b9690; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 0.75rem;">
      Blog
    </p>
    <h1 style="font-family: Georgia, serif; font-weight: 300; font-size: 2rem; color: #1a1a1a; margin: 0;">
      Writing
    </h1>
  </section>

  <section style="padding: 1rem 3rem 4rem; max-width: 800px;">
    {posts.map(post => (
      <div style="padding: 1.75rem 0; border-bottom: 0.5px solid #d8d4ce;">
        <p style="font-size: 11px; color: #9b9690; margin: 0 0 0.4rem;">
          {post.data.date.toISOString().slice(0, 10)}
        </p>
        <a
          href={`/portfolio/blog/${post.id.replace(/\.md$/, '')}/`}
          style="color: #1a1a1a; text-decoration: none; font-size: 15px; font-weight: 500;"
        >
          {post.data.title}
        </a>
        <p style="font-size: 13px; color: #6b6b6b; margin: 0.4rem 0 0.75rem; line-height: 1.6;">
          {post.data.description}
        </p>
        {post.data.tags && (
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {post.data.tags.map(tag => (
              <span style="background: #e4e0da; color: #9b9690; font-size: 11px; padding: 3px 8px;">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    ))}
  </section>
</Layout>
