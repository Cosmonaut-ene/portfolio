---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Zhang`}>
  <article style="padding: 4rem 3rem; max-width: 720px;">
    <p style="font-size: 11px; color: #9b9690; margin: 0 0 1rem;">
      {post.data.date.toISOString().slice(0, 10)}
    </p>
    <h1 style="font-family: Palatino, 'Palatino Linotype', serif; font-weight: 300; font-size: 2rem; color: #1a1a1a; margin: 0 0 2.5rem; line-height: 1.3;">
      {post.data.title}
    </h1>
    <div class="prose" style="font-size: 15px; color: #6b6b6b; line-height: 1.8;">
      <Content />
    </div>
  </article>
</Layout>
